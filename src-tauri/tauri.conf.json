{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "NIIMBOT D11",
  "version": "0.1.0",
  "identifier": "app.niimbot.d11",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "NIIMBOT D11",
        "width": 1120,
        "height": 680,
        "minWidth": 960,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "exceptionDomain": "",
      "frameworks": [],
      "entitlements": null,
      "providerShortName": null,
      "signingIdentity": null,
      "hardenedRuntime": false,
      "infoPlist": "Info.plist"
    }
  }
}
